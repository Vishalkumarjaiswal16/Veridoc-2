      "source": [
        "from scipy.spatial.distance import cosine\n",
        "\n",
        "print(\"=\" * 50)\n",
        "print(\"COSINE SIMILARITY MATRIX\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "# Compute cosine similarity matrix\n",
        "n = len(sample_texts)\n",
        "similarity_matrix = np.zeros((n, n))\n",
        "\n",
        "for i in range(n):\n",
        "    for j in range(n):\n",
        "        similarity_matrix[i, j] = 1 - cosine(embeddings[i], embeddings[j])\n",
        "\n",
        "# Display as formatted table\n",
        "print(\"\\nSimilarity scores (higher = more similar):\")\n",
        "print(\"\\n     \", end=\"\")\n",
        "for i in range(n):\n",
        "    print(f\"  [{i}]  \", end=\"\")\n",
        "print()\n",
        "\n",
        "for i in range(n):\n",
        "    print(f\"[{i}] \", end=\"\")\n",
        "    for j in range(n):\n",
        "        print(f\" {similarity_matrix[i, j]:.3f} \", end=\"\")\n",
        "    print()\n",
        "\n",
        "# Find most similar pairs (excluding self-similarity)\n",
        "print(\"\\n\\nMost Similar Text Pairs:\")\n",
        "pairs = []\n",
        "for i in range(n):\n",
        "    for j in range(i + 1, n):\n",
        "        pairs.append((i, j, similarity_matrix[i, j]))\n",
        "\n",
        "pairs.sort(key=lambda x: x[2], reverse=True)\n",
        "for i, j, sim in pairs[:3]:\n",
        "    print(f\"  {sim:.3f}: [{i}] vs [{j}]\")\n",
        "    print(f\"         '{sample_texts[i][:50]}...'\")\n",
        "    print(f\"         '{sample_texts[j][:50]}...'\")"
      ]
    },
