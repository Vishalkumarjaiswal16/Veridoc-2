      "source": [
        "print(\"=\" * 50)\n",
        "print(\"BATCH PROCESSING BENCHMARK\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "# Generate test data of varying sizes\n",
        "test_sizes = [10, 50, 100, 500]\n",
        "base_text = \"This is a sample text for benchmarking embedding generation performance. \"\n",
        "\n",
        "results = []\n",
        "for size in test_sizes:\n",
        "    # Create batch of texts\n",
        "    batch = [f\"{base_text} Sample {i}\" for i in range(size)]\n",
        "    \n",
        "    # Benchmark\n",
        "    start = time.time()\n",
        "    _ = manager.embed_texts(batch)\n",
        "    elapsed = time.time() - start\n",
        "    \n",
        "    texts_per_sec = size / elapsed\n",
        "    results.append((size, elapsed, texts_per_sec))\n",
        "    print(f\"  Batch size {size:4d}: {elapsed:.3f}s ({texts_per_sec:.1f} texts/sec)\")\n",
        "\n",
        "avg_speed = sum(r[2] for r in results) / len(results)\n",
        "print(f\"\\n✓ Average throughput: {avg_speed:.1f} texts/second\")"
      ]
    },
